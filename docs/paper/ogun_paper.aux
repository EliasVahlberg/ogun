\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces PathFinder negotiation resolving a routing conflict. (a)~Two routes (blue: A$\to $B, red: C$\to $D) share a cell ($s=2$). (b)~The shared cell receives a history penalty $h + \delta $, increasing its cost. (c)~On the next iteration, the lower-weight route (red) detours around the now-expensive cell, eliminating the conflict.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:pathfinder}{{3}{5}{PathFinder negotiation resolving a routing conflict. (a)~Two routes (blue: A$\to $B, red: C$\to $D) share a cell ($s=2$). (b)~The shared cell receives a history penalty $h + \delta $, increasing its cost. (c)~On the next iteration, the lower-weight route (red) detours around the now-expensive cell, eliminating the conflict}{figure.3}{}}
